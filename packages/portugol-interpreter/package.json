{
  "name": "portugol-interpreter",
  "version": "1.0.0",
  "description": "A TypeScript interpreter for Portugol (Portuguese pseudocode compatible with VisuAlg)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "jest --passWithNoTests",
    "type-check": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hansufsm/idealg.git",
    "directory": "packages/portugol-interpreter"
  },
  "keywords": [
    "portugol",
    "visualg",
    "interpreter",
    "pseudocode",
    "portuguese"
  ],
  "author": "Hans",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  }
}
